---
import Seo from '../components/Seo.astro';
const { title, description, jsonLd, canonicalPath } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <Seo title={title} description={description} jsonLd={jsonLd} canonicalPath={canonicalPath} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Spectral:wght@500;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        /* Manuscript / liturgical palette */
        --ink: #1a1f2e;          /* deep ink for body text */
        --oxblood: #6b2034;      /* liturgical oxblood, used for headings */
        --indigo: #1f2a4a;       /* deep liturgical blue */
        --gold: #b08436;         /* muted manuscript gold — the one accent */
        --gold-bright: #caa353;
        --parchment: #f7f3ea;    /* warm page ground */
        --parchment-deep: #efe8d8;
        --rule: #ddd2bb;         /* hairline rules */
        --muted: #6e6a5b;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        * { animation: none !important; transition: none !important; }
      }
      body {
        margin: 0;
        background: var(--parchment);
        color: var(--ink);
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.18rem;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--oxblood); text-decoration-thickness: 1px; text-underline-offset: 2px; }
      a:hover { color: var(--gold); }
      :focus-visible { outline: 2px solid var(--gold); outline-offset: 3px; }

      .wrap { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }

      header.site {
        border-bottom: 1px solid var(--rule);
        background: var(--parchment-deep);
        position: relative;
      }
      header.site .bar {
        max-width: 960px; margin: 0 auto; padding: 0.9rem 1.5rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      }
      .brand {
        font-family: 'Spectral', serif; font-weight: 700; font-size: 1.15rem;
        color: var(--indigo); text-decoration: none; letter-spacing: 0.01em;
      }
      .brand:hover { color: var(--oxblood); }
      nav.versions { display: flex; gap: 1.1rem; font-family: 'Inter', sans-serif; font-size: 0.82rem; }
      nav.versions a {
        text-transform: uppercase; letter-spacing: 0.08em; color: var(--indigo);
        text-decoration: none; font-weight: 600;
      }
      nav.versions a:hover { color: var(--gold); }

      /* Hamburger button — hidden on desktop, shown on mobile */
      .nav-toggle {
        display: none;
        background: none; border: 1px solid var(--rule); border-radius: 4px;
        padding: 0.45rem 0.55rem; cursor: pointer; line-height: 0;
        color: var(--indigo);
      }
      .nav-toggle:hover { border-color: var(--gold); }
      .nav-toggle svg { display: block; }
      .nav-toggle .icon-close { display: none; }
      .nav-toggle[aria-expanded='true'] .icon-open { display: none; }
      .nav-toggle[aria-expanded='true'] .icon-close { display: block; }

      @media (max-width: 640px) {
        header.site .bar { padding: 0.8rem 1.1rem; }
        .nav-toggle { display: block; }

        nav.versions {
          display: none;
          position: absolute; left: 0; right: 0; top: 100%;
          z-index: 50;
          flex-direction: column; gap: 0;
          background: var(--parchment-deep);
          border-bottom: 1px solid var(--rule);
          box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
          padding: 0.4rem 0;
        }
        nav.versions.open { display: flex; }
        nav.versions a {
          padding: 0.85rem 1.1rem;
          border-top: 1px solid var(--rule);
          font-size: 0.85rem;
        }
        nav.versions a:first-child { border-top: none; }
      }

      footer.site {
        margin-top: 4rem; border-top: 1px solid var(--rule);
        background: var(--parchment-deep);
        font-family: 'Inter', sans-serif; font-size: 0.82rem; color: #5b5a52;
      }
      footer.site .wrap { padding-top: 1.5rem; padding-bottom: 2rem; }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="bar">
        <a class="brand" href="/">Orthodox Christian Bible</a>

        <button
          class="nav-toggle"
          id="nav-toggle"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Menu"
        >
          <svg class="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="5" y1="5" x2="19" y2="19" />
            <line x1="19" y1="5" x2="5" y2="19" />
          </svg>
        </button>

        <nav class="versions" id="site-nav" aria-label="Site sections">
          <a href="/readings/">Daily Readings</a>
          <a href="/prayers/">Prayers</a>
          <a href="/articles/">Articles</a>
          <a href="/bible/kjv/">KJV</a>
          <a href="/bible/brenton/">Septuagint</a>
          <a href="/search/">Search</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <div class="wrap">
        Public-domain texts (KJV 1611, Brenton's Septuagint 1851).
        Also available as an iOS app.
      </div>
    </footer>

    <script is:inline>
      (function () {
        var btn = document.getElementById('nav-toggle');
        var nav = document.getElementById('site-nav');
        if (!btn || !nav) return;

        function setOpen(open) {
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          nav.classList.toggle('open', open);
        }

        btn.addEventListener('click', function () {
          setOpen(btn.getAttribute('aria-expanded') !== 'true');
        });

        // Close when a link is tapped.
        nav.addEventListener('click', function (e) {
          if (e.target.tagName === 'A') setOpen(false);
        });

        // Close on Escape, and return focus to the button.
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
            setOpen(false);
            btn.focus();
          }
        });

        // Close when tapping outside the header.
        document.addEventListener('click', function (e) {
          if (
            btn.getAttribute('aria-expanded') === 'true' &&
            !e.target.closest('header.site')
          ) {
            setOpen(false);
          }
        });

        // If the viewport grows past the mobile breakpoint, reset state.
        window.addEventListener('resize', function () {
          if (window.innerWidth > 640) setOpen(false);
        });
      })();
    </script>
  </body>
</html>
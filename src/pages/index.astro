---
import Base from '../layouts/Base.astro';
import { VERSIONS } from '../data/versions.js';
import { APP } from '../data/app.js';
import { REVIEWS } from '../data/reviews.js';

const title = 'Orthodox Christian Bible - Prayers, Scripture & the Church Fathers';
const description =
  'Read the Bible online, pray the daily prayers of the Orthodox Church, follow the calendar, and explore the Church Fathers. Also available as a free iOS app.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Orthodox Christian Bible',
  url: Astro.site?.href,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${Astro.site?.href}search/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---
<Base title={title} description={description} jsonLd={jsonLd} canonicalPath="/">
  <!-- APP FUNNEL HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">The Orthodoxy App</p>
        <h1>Your complete Orthodox Christian companion.</h1>
        <p class="lede">
          Prayers, the Bible, the liturgical calendar, and the writings of the
          Church Fathers, all in one place. Built for prayer, Scripture, and
          the spiritual life.
        </p>
        <div class="cta-row">
          <a class="app-btn" href={APP.appStoreUrl} aria-label="Download on the App Store">
            Download on the App Store
          </a>
          <a class="ghost-btn" href="#read">Read the Bible online ↓</a>
        </div>
        <p class="cost-note">
          Prayer library, calendar, and Bible included free. An optional
          subscription supports development.
        </p>
      </div>
      <div class="hero-art" aria-hidden="true">
        <div class="phone">
          <span class="halo"></span>
          <span class="verse-card">
            <span class="vc-label">Verse of the Day</span>
            <span class="vc-text">For God so loved the world…</span>
            <span class="vc-ref">John 3:16</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE HIGHLIGHTS -->
  <section class="features wrap">
    <h2 class="section-title">Everything for the daily life of faith</h2>
    <div class="feature-grid">
      {APP.features.map((f) => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
    <div class="features-cta">
      <a class="app-btn" href={APP.appStoreUrl}>Get the app</a>
    </div>
  </section>

  <!-- BIBLE READING (the site's own indexable content) -->
  <section id="read" class="read">
    <div class="wrap">
      <h2 class="section-title">Read the Bible online free, no app needed</h2>
      <p class="read-lede">
        The full text, searchable and linkable, right in your browser. Open to
        any chapter and verse.
      </p>

      <form class="lookup" action="/search/" method="get" role="search">
        <label for="q" class="sr">Find a verse</label>
        <input id="q" name="q" type="search" placeholder="Search a verse or word — e.g. John 3:16" autocomplete="off" />
        <button type="submit">Find</button>
      </form>

      <div class="versions-list">
        {VERSIONS.map((v) => (
          <a class="vcard" href={`/bible/${v.slug}/`}>
            <span class="vabbr">{v.abbr}</span>
            <span class="vbody">
              <strong>{v.name}</strong>
              <span class="vmeta">{v.year} · {v.license}</span>
              <span class="vdesc">{v.description}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="reviews">
    <div class="wrap">
      <h2 class="section-title">What people are saying</h2>

      <div class="carousel" id="reviews-carousel">
        <div class="track" id="reviews-track">
          {REVIEWS.map((r) => (
            <article class="review-card">
              <div class="stars" aria-label={`${r.rating} out of 5 stars`} aria-hidden="true">
                {'★'.repeat(r.rating)}
              </div>
              <h3>{r.title}</h3>
              <p class="review-text">{r.text}</p>
              <p class="review-meta">{r.author} · App Store · {r.date}</p>
            </article>
          ))}
        </div>

        <button class="arrow prev" id="reviews-prev" type="button" aria-label="Previous review">‹</button>
        <button class="arrow next" id="reviews-next" type="button" aria-label="Next review">›</button>
      </div>

      <div class="dots" id="reviews-dots" role="tablist" aria-label="Choose a review">
        {REVIEWS.map((_, i) => (
          <button class="dot" type="button" data-index={i} role="tab" aria-label={`Show review ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var carousel = document.getElementById('reviews-carousel');
      var track = document.getElementById('reviews-track');
      var prevBtn = document.getElementById('reviews-prev');
      var nextBtn = document.getElementById('reviews-next');
      var dotsWrap = document.getElementById('reviews-dots');
      if (!carousel || !track || !prevBtn || !nextBtn || !dotsWrap) return;

      var dots = Array.prototype.slice.call(dotsWrap.querySelectorAll('.dot'));
      var count = track.children.length;
      var index = 0;

      // Reviews vary a lot in length, so size the carousel to the card
      // that's actually in view rather than the tallest one in the set
      // (a plain flex row would otherwise stretch to the longest review
      // and leave the arrows floating far below short ones).
      function render() {
        track.style.transform = 'translateX(-' + index * 100 + '%)';
        carousel.style.height = track.children[index].offsetHeight + 'px';
        dots.forEach(function (dot, i) {
          var active = i === index;
          dot.classList.toggle('active', active);
          dot.setAttribute('aria-selected', active ? 'true' : 'false');
        });
      }

      function goTo(i) {
        index = (i + count) % count;
        render();
      }

      prevBtn.addEventListener('click', function () { goTo(index - 1); });
      nextBtn.addEventListener('click', function () { goTo(index + 1); });
      dots.forEach(function (dot, i) {
        dot.addEventListener('click', function () { goTo(i); });
      });

      // Re-measure on resize: text reflow at a new width changes card height.
      window.addEventListener('resize', render);

      render();
    })();
  </script>

  <style>
    .sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }

    /* ---- HERO ---- */
    .hero { background: var(--indigo); color: var(--parchment); padding: 4rem 0 4.5rem; overflow: hidden; }
    .hero-inner {
      max-width: 1040px; margin: 0 auto; padding: 0 1.5rem;
      display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2.5rem; align-items: center;
    }
    .eyebrow {
      font-family: 'Inter', sans-serif; text-transform: uppercase; letter-spacing: 0.18em;
      font-size: 0.74rem; color: var(--gold-bright); margin: 0 0 1rem;
    }
    .hero h1 {
      font-family: 'Spectral', serif; font-weight: 700; font-size: clamp(2.3rem, 5vw, 3.6rem);
      line-height: 1.04; margin: 0 0 1.1rem; color: var(--parchment);
    }
    .lede { font-size: 1.18rem; color: #d8d2c2; margin: 0 0 1.8rem; max-width: 42ch; }
    .cta-row { display: flex; flex-wrap: wrap; gap: 0.8rem; align-items: center; }
    .app-btn {
      display: inline-block; background: var(--gold); color: var(--indigo);
      font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.98rem;
      padding: 0.9rem 1.5rem; border-radius: 6px; text-decoration: none;
    }
    .app-btn:hover { background: var(--gold-bright); color: var(--indigo); }
    .ghost-btn {
      font-family: 'Inter', sans-serif; font-size: 0.95rem; color: var(--gold-bright);
      text-decoration: none; font-weight: 500;
    }
    .ghost-btn:hover { color: var(--parchment); }
    .cost-note { font-family: 'Inter', sans-serif; font-size: 0.8rem; color: #b9b2a0; margin-top: 1.2rem; }

    /* phone mock signature */
    .hero-art { display: flex; justify-content: center; }
    .phone {
      position: relative; width: 220px; height: 440px; border-radius: 32px;
      background: linear-gradient(160deg, #25315a, #161f3a); border: 2px solid #34406b;
      box-shadow: 0 30px 60px rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center;
    }
    .halo {
      position: absolute; width: 260px; height: 260px; border-radius: 50%;
      background: radial-gradient(circle, rgba(202,163,83,0.35), transparent 70%); filter: blur(8px);
    }
    .verse-card {
      position: relative; width: 168px; padding: 1.3rem 1.1rem; border-radius: 14px;
      background: var(--parchment); color: var(--ink); display: flex; flex-direction: column; gap: 0.5rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    }
    .vc-label {
      font-family: 'Inter', sans-serif; font-size: 0.62rem; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--gold);
    }
    .vc-text { font-family: 'Spectral', serif; font-size: 1.05rem; line-height: 1.35; color: var(--oxblood); }
    .vc-ref { font-family: 'Inter', sans-serif; font-size: 0.72rem; color: var(--muted); }

    /* ---- SECTION SHARED ---- */
    .section-title {
      font-family: 'Spectral', serif; font-weight: 700; color: var(--oxblood);
      font-size: clamp(1.7rem, 4vw, 2.4rem); margin: 0 0 0.6rem; line-height: 1.1;
    }

    /* ---- FEATURES ---- */
    .features { padding-top: 3.5rem; }
    .feature-grid {
      margin-top: 1.8rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.4rem;
    }
    .feature { border-top: 2px solid var(--gold); padding-top: 1rem; }
    .feature h3 { font-family: 'Spectral', serif; color: var(--indigo); font-size: 1.2rem; margin: 0 0 0.4rem; }
    .feature p { font-size: 1rem; color: #4a4a44; margin: 0; }
    .features-cta { margin-top: 2.4rem; }

    /* ---- READ / BIBLE ---- */
    .read { margin-top: 3.5rem; background: var(--parchment-deep); padding: 3rem 0 3.5rem; border-top: 1px solid var(--rule); }
    .read-lede { color: #4a4a44; max-width: 48ch; margin: 0 0 1.6rem; }
    .lookup { display: flex; gap: 0.5rem; max-width: 520px; margin-bottom: 2rem; }
    .lookup input {
      flex: 1; padding: 0.8rem 1rem; border: 1px solid var(--gold); border-radius: 4px;
      background: #fff; color: var(--ink); font-family: 'EB Garamond', serif; font-size: 1.05rem;
    }
    .lookup button {
      padding: 0.8rem 1.3rem; border: none; border-radius: 4px; cursor: pointer;
      background: var(--gold); color: var(--indigo); font-family: 'Inter', sans-serif; font-weight: 600;
    }
    .lookup button:hover { background: var(--gold-bright); }
    .versions-list { display: grid; gap: 1rem; }
    .vcard {
      display: flex; gap: 1.3rem; align-items: flex-start; text-decoration: none; color: var(--ink);
      border: 1px solid var(--rule); border-radius: 6px; padding: 1.3rem 1.4rem; background: #fff;
      transition: border-color 0.15s;
    }
    .vcard:hover { border-color: var(--gold); }
    .vabbr { font-family: 'Spectral', serif; font-weight: 700; font-size: 1.5rem; color: var(--gold); min-width: 2.5rem; }
    .vbody { display: flex; flex-direction: column; gap: 0.25rem; }
    .vbody strong { font-family: 'Spectral', serif; color: var(--indigo); font-size: 1.15rem; }
    .vmeta {
      font-family: 'Inter', sans-serif; font-size: 0.74rem; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--muted);
    }
    .vdesc { color: #4a4a44; font-size: 1rem; }

    /* ---- REVIEWS ---- */
    .reviews { margin-top: 3.5rem; padding: 3rem 0 3.5rem; }
    .carousel { position: relative; overflow: hidden; transition: height 0.35s ease; }
    .track { display: flex; align-items: flex-start; transition: transform 0.35s ease; }
    .review-card {
      flex: 0 0 100%; box-sizing: border-box; padding: 0.2rem 3.2rem;
      display: flex; flex-direction: column; gap: 0.7rem; text-align: center; align-items: center;
    }
    .stars { color: var(--gold); font-size: 1.1rem; letter-spacing: 0.15em; }
    .review-card h3 {
      font-family: 'Spectral', serif; font-weight: 700; color: var(--oxblood);
      font-size: 1.3rem; margin: 0;
    }
    .review-text {
      font-size: 1.08rem; line-height: 1.7; color: #4a4a44; max-width: 56ch;
    }
    .review-meta {
      font-family: 'Inter', sans-serif; font-size: 0.78rem; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--muted); margin: 0;
    }

    .arrow {
      position: absolute; top: 50%; transform: translateY(-50%);
      width: 2.4rem; height: 2.4rem; border-radius: 50%; border: 1px solid var(--rule);
      background: #fff; color: var(--indigo); font-size: 1.4rem; line-height: 1; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
    }
    .arrow:hover { border-color: var(--gold); color: var(--oxblood); }
    .arrow.prev { left: 0; }
    .arrow.next { right: 0; }

    .dots { display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.6rem; }
    .dot {
      width: 0.55rem; height: 0.55rem; border-radius: 50%; border: none;
      background: var(--rule); cursor: pointer; padding: 0;
    }
    .dot.active { background: var(--gold); }

    @media (max-width: 760px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-art { order: -1; }
      .phone { width: 170px; height: 340px; }
    }

    @media (max-width: 640px) {
      .review-card { padding: 0.2rem 2.6rem; }
    }
  </style>
</Base>

---
import Base from '../layouts/Base.astro';
import { VERSIONS } from '../data/versions.js';

const title = 'Orthodox Christian Bible — KJV & Septuagint Online';
const description =
  'Read the King James Version and Brenton\u2019s Septuagint online. Find any verse instantly. The Orthodox Christian Bible, also available as an iOS app.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Orthodox Christian Bible',
  url: Astro.site?.href,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${Astro.site?.href}search/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---
<Base title={title} description={description} jsonLd={jsonLd} canonicalPath="/">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">King James Version · Brenton's Septuagint</p>
      <h1>The Word, read plainly.</h1>
      <p class="lede">
        Two complete public-domain translations at the heart of Orthodox reading —
        searchable, linkable, and fast. Open to any chapter and verse.
      </p>

      <form class="lookup" action="/search/" method="get" role="search">
        <label for="q" class="sr">Find a verse</label>
        <input id="q" name="q" type="search" placeholder="Search a verse or word — e.g. John 3:16" autocomplete="off" />
        <button type="submit">Find</button>
      </form>

      <p class="sample">
        Try <a href="/bible/kjv/john/3#v16">John 3:16</a> ·
        <a href="/bible/brenton/genesis/1#v1">Genesis 1:1 (LXX)</a>
      </p>
    </div>
  </section>

  <section class="wrap versions-list">
    {VERSIONS.map((v) => (
      <a class="vcard" href={`/bible/${v.slug}/`}>
        <span class="vabbr">{v.abbr}</span>
        <span class="vbody">
          <strong>{v.name}</strong>
          <span class="vmeta">{v.year} · {v.license}</span>
          <span class="vdesc">{v.description}</span>
        </span>
      </a>
    ))}
  </section>

  <style>
    .sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
    .hero { background: var(--indigo); color: var(--parchment); padding: 4.5rem 0 4rem; }
    .eyebrow {
      font-family: 'Inter', sans-serif; text-transform: uppercase; letter-spacing: 0.18em;
      font-size: 0.74rem; color: var(--gold-bright); margin: 0 0 1rem;
    }
    .hero h1 {
      font-family: 'Spectral', serif; font-weight: 700; font-size: clamp(2.6rem, 8vw, 4.4rem);
      line-height: 1.0; margin: 0 0 1.2rem; color: var(--parchment);
    }
    .lede { font-size: 1.22rem; max-width: 34ch; color: #d8d2c2; margin: 0 0 2rem; }

    .lookup { display: flex; gap: 0.5rem; max-width: 520px; }
    .lookup input {
      flex: 1; padding: 0.85rem 1rem; border: 1px solid var(--gold); border-radius: 4px;
      background: var(--parchment); color: var(--ink); font-family: 'EB Garamond', serif;
      font-size: 1.05rem;
    }
    .lookup button {
      padding: 0.85rem 1.4rem; border: none; border-radius: 4px; cursor: pointer;
      background: var(--gold); color: var(--indigo); font-family: 'Inter', sans-serif;
      font-weight: 600; font-size: 0.95rem;
    }
    .lookup button:hover { background: var(--gold-bright); }
    .sample { font-size: 0.95rem; color: #cdc6b4; margin-top: 1.1rem; }
    .sample a { color: var(--gold-bright); }

    .versions-list { padding-top: 3rem; display: grid; gap: 1rem; }
    .vcard {
      display: flex; gap: 1.3rem; align-items: flex-start; text-decoration: none;
      color: var(--ink); border: 1px solid var(--rule); border-radius: 6px;
      padding: 1.4rem 1.5rem; background: #fff; transition: border-color 0.15s;
    }
    .vcard:hover { border-color: var(--gold); }
    .vabbr {
      font-family: 'Spectral', serif; font-weight: 700; font-size: 1.5rem;
      color: var(--gold); min-width: 2.5rem;
    }
    .vbody { display: flex; flex-direction: column; gap: 0.25rem; }
    .vbody strong { font-family: 'Spectral', serif; color: var(--indigo); font-size: 1.2rem; }
    .vmeta {
      font-family: 'Inter', sans-serif; font-size: 0.74rem; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--muted);
    }
    .vdesc { color: #4a4a44; font-size: 1.02rem; }
  </style>
</Base>

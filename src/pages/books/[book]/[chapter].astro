---
import Base from '../../../layouts/Base.astro';

// Same discovery approach as the book index: one JSON file per whole book,
// so every entry in its `chapters` array becomes one static page here.
export async function getStaticPaths() {
  const files = import.meta.glob('../../../data/books/*/*.json', { eager: true });
  const paths = [];

  for (const path in files) {
    const slug = path.split('/').at(-2);
    const data = files[path].default;
    const book = data.books[0];

    book.chapters.forEach((ch, i) => {
      paths.push({
        params: { book: slug, chapter: String(ch.chapter) },
        props: {
          slug,
          name: book.name,
          translation: data.translation,
          chapter: ch.chapter,
          verses: ch.verses,
          prev: i > 0 ? book.chapters[i - 1].chapter : null,
          next: i < book.chapters.length - 1 ? book.chapters[i + 1].chapter : null,
        },
      });
    });
  }
  return paths;
}

const { slug, name, translation, chapter, verses, prev, next } = Astro.props;
const ref = `${name} ${chapter}`;

// SEO: title and description follow the same pattern as Bible chapter pages.
const title = `${ref} | Orthodox Christian Bible`;
const firstVerse = verses[0]?.text ?? '';
const description = `Read ${ref}. ${firstVerse}`.slice(0, 155);

// JSON-LD structured data — same shape as the Bible chapter page's.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: ref,
  about: ref,
  isPartOf: { '@type': 'Book', name },
  inLanguage: 'en',
  url: new URL(Astro.url.pathname, Astro.site).href,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Books', item: new URL('/books/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name, item: new URL(`/books/${slug}/`, Astro.site).href },
      { '@type': 'ListItem', position: 3, name: ref },
    ],
  },
};
---
<Base title={title} description={description} jsonLd={jsonLd}>
  <article class="wrap chapter">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/books/">Books</a>
      <span aria-hidden="true">·</span>
      <a href={`/books/${slug}/`}>{name}</a>
    </nav>

    <h1>{name} <span class="num">{chapter}</span></h1>
    <p class="version-note">{translation}</p>

    <div class="text" data-pagefind-body data-pagefind-filter={`Book:${name}`} data-pagefind-meta={`reference:${ref}`}>
      {verses.map((verse) => (
        <p class="verse" id={`v${verse.verse}`}>
          <a class="vn" href={`#v${verse.verse}`} aria-label={`Verse ${verse.verse}`}>{verse.verse}</a>
          <span class="vt">{verse.text}</span>
        </p>
      ))}
    </div>

    <nav class="pager" aria-label="Chapter navigation">
      {prev ? <a rel="prev" href={`/books/${slug}/${prev}`}>← {name} {prev}</a> : <span></span>}
      {next ? <a rel="next" href={`/books/${slug}/${next}`}>{name} {next} →</a> : <span></span>}
    </nav>
  </article>

  <style>
    .crumbs {
      font-family: 'Inter', sans-serif; font-size: 0.78rem; text-transform: uppercase;
      letter-spacing: 0.08em; margin-top: 2rem; color: var(--muted);
    }
    .crumbs a { color: var(--indigo); text-decoration: none; }
    .crumbs span { margin: 0 0.5rem; color: var(--rule); }

    h1 {
      font-family: 'Spectral', serif; font-weight: 700; color: var(--oxblood);
      font-size: clamp(2.2rem, 6vw, 3.2rem); margin: 0.6rem 0 0; line-height: 1.05;
    }
    h1 .num { color: var(--gold); }
    .version-note {
      font-family: 'Inter', sans-serif; font-size: 0.8rem; color: var(--muted);
      margin: 0.3rem 0 2.2rem; letter-spacing: 0.02em;
    }

    .text { border-top: 1px solid var(--rule); padding-top: 1.8rem; }
    .verse { margin: 0 0 0.5rem; text-indent: 0; }
    .vn {
      font-family: 'Inter', sans-serif; font-size: 0.7rem; font-weight: 600;
      color: var(--gold); vertical-align: super; text-decoration: none;
      margin-right: 0.45rem; min-width: 1.1em; display: inline-block;
    }
    .vn:hover { color: var(--oxblood); }
    .vt { }

    /* Signature: illuminated drop-initial on the first verse of the chapter */
    .text .verse:first-of-type .vt::first-letter {
      font-family: 'Spectral', serif; font-weight: 700;
      font-size: 3.1rem; line-height: 0.8; float: left;
      padding: 0.35rem 0.6rem 0 0; color: var(--gold);
    }
    .verse:target { background: var(--parchment-deep); border-radius: 4px; }

    .pager {
      display: flex; justify-content: space-between; gap: 1rem; margin-top: 3rem;
      padding-top: 1.4rem; border-top: 1px solid var(--rule);
      font-family: 'Inter', sans-serif; font-size: 0.9rem;
    }
    .pager a { text-decoration: none; font-weight: 500; }
  </style>
</Base>
